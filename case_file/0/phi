FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      phi;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 2 -3 0 0 -1 0];

internalField   uniform 0;

boundaryField
{
    floor
    {
        type            fixedValue;
        value           uniform 0;
    }
    ceiling
    {
        type            fixedValue;
        value           uniform 0;
    }
    electrode
    {
        type            fixedValue;
        value           uniform -0.45;
    }
    electrolyte
    {
        type            fixedValue;
        value           uniform 0;
    }
}

