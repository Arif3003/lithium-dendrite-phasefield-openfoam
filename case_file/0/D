FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      D;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 0 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    
    floor
    {
        type            zeroGradient;
        // traction        uniform (0 0 0);
        // pressure        uniform 0;
        // value           uniform (0 0 0);
    }
    
    ceiling
    {
        type            zeroGradient;
        // traction        uniform (0 0 0);
        // pressure        uniform 0;
        // value           uniform (0 0 0);
    }
    
    electrode
    {
        // Keep this clamped! It does not need pressure.
        type            fixedValue;
        value           uniform (0 0 0);
    }
    
    electrolyte
    {
        type            zeroGradient;
        // traction        uniform (0 0 0);
        // pressure        uniform 0;
        // value           uniform (0 0 0);
    }
    frontAndBack
    {
        type            empty;
    }
}

