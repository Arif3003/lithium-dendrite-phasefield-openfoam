FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      eta;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    floor
    {
        type            zeroGradient;
    }
    ceiling
    {
        type            zeroGradient;
    }
    electrode
    {
        type           zeroGradient;
    }
    electrolyte
    {
        type            zeroGradient;
    }  
}

