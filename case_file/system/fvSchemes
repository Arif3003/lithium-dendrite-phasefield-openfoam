FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

d2dt2Schemes
{
    default         steadyState;
}
ddtSchemes
{
    //default         CrankNicolson 0.9;
   default          Euler;
}

gradSchemes
{
    default         Gauss linear;
    grad(muC)         Gauss linear;
    //grad(D)         leastSquares;
}

divSchemes
{
    default         Gauss linear;
   // div(sigmaD)     Gauss linear;
}

laplacianSchemes
{
    default         Gauss linear corrected;
    //laplacian(DT,T) Gauss linear corrected;
    //laplacian(DD,D) Gauss linear corrected;
    //laplacian(DTs,T) Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}


