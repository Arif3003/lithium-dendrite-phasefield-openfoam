defaultFieldValues
(
    volScalarFieldValue eta 0
    volScalarFieldValue muC 0.036
    volScalarFieldValue phi 0
    volScalarFieldValue c 1
);

regions
(
//Set patch values (using ==)   
     cylinderToCell
     {
         p1 (0 100 0);
         p2 (0 100 1);
 	      radius 8;

         fieldValues
         (
           volScalarFieldValue eta 1.0
           volScalarFieldValue muC -11.0
           volScalarFieldValue phi -0.45
           volScalarFieldValue c 0
         );
     }
